{
  "name": "xmind-to-markdown-desktop",
  "version": "2.0.0",
  "description": "Local XMind to Markdown app for macOS",
  "main": "main.js",
  "author": "majindou",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack:mac:intel": "electron-builder --mac dmg --x64"
  },
  "devDependencies": {
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.majindou.xmind2md",
    "productName": "XMind2Markdown",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "app.js"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
